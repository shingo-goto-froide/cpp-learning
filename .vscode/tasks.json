{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++.exe build with all.h",
            "command": "mingw32-make",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Makefile を使ってビルド"
        },
        {
            "type": "shell",
            "label": "C/C++: build and run",
            "command": "mingw32-make",
            "args": ["run"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Makefile を使ってビルド＆実行"
        }
    ]
}